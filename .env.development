# ============================================================
# 开发环境配置示例
# ============================================================

# Dangbei API
DANGBEI_BASE_URL=https://ai-api.dangbei.net

# 服务器
HOST=127.0.0.1
PORT=8000

# 模型
DEFAULT_MODEL=deepseek-v3
DEFAULT_USER_ACTION=online,deep

# 鉴权（开发环境可留空）
API_KEY=

# 会话管理（开发环境使用内存）
SESSION_EXPIRE_SECONDS=1800
SESSION_CLEANUP_INTERVAL=300
USE_SQLITE_SESSION=false

# 日志（开发环境使用彩色输出）
LOG_LEVEL=DEBUG
LOG_JSON=false

# 限流（开发环境可放宽）
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120

# 性能
HTTP_TIMEOUT=300
HTTP_MAX_CONNECTIONS=50
MODEL_CACHE_TTL=3600
