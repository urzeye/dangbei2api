# Dangbei API Base URL
DANGBEI_BASE_URL=https://ai-api.dangbei.net

# Server config
HOST=0.0.0.0
PORT=8000

# Default model (used when not specified)
DEFAULT_MODEL=deepseek-v3

# Optional: API Key for authentication (leave empty to disable auth)
# Set this to require Authorization: Bearer <key> on all requests
# API_KEY=your-secret-key

# Optional: User token for logged-in mode (supports file upload)
# DANGBEI_TOKEN=your_token_here
