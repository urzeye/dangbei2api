# ============================================================
# Dangbei API 配置
# ============================================================

# 当贝 API 基础 URL
DANGBEI_BASE_URL=https://ai-api.dangbei.net

# 可选：用户 token（登录模式，支持文件上传）
# 留空则为匿名模式
# DANGBEI_TOKEN=your_token_here

# ============================================================
# 服务器配置
# ============================================================

# 监听地址
HOST=0.0.0.0

# 监听端口
PORT=8000

# ============================================================
# 模型配置
# ============================================================

# 默认模型（未指定时使用）
DEFAULT_MODEL=deepseek-v3

# 默认用户行为（无后缀模型时生效）
# 可选值：online（联网）、deep（深度思考）、online,deep（两者都开启）
DEFAULT_USER_ACTION=online,deep

# ============================================================
# 鉴权配置
# ============================================================

# 可选：API Key（留空则不校验）
# 设置后客户端必须带 Authorization: Bearer <key>
# API_KEY=your-secret-key

# ============================================================
# 会话管理
# ============================================================

# 会话过期时间（秒），0 表示永不过期
SESSION_EXPIRE_SECONDS=1800

# 会话清理任务间隔（秒）
SESSION_CLEANUP_INTERVAL=300

# 是否使用 SQLite 存储会话（默认使用内存）
USE_SQLITE_SESSION=false

# SQLite 数据库文件路径（USE_SQLITE_SESSION=true 时生效）
SQLITE_DB_PATH=data/sessions.db

# ============================================================
# 日志配置
# ============================================================

# 日志级别：DEBUG、INFO、WARNING、ERROR
LOG_LEVEL=INFO

# 是否输出 JSON 格式日志（生产环境推荐开启）
LOG_JSON=false

# ============================================================
# 限流配置
# ============================================================

# 是否启用限流
RATE_LIMIT_ENABLED=true

# 每分钟请求限制
RATE_LIMIT_PER_MINUTE=60

# ============================================================
# 性能配置
# ============================================================

# HTTP 请求超时时间（秒）
HTTP_TIMEOUT=300

# HTTP 最大连接数
HTTP_MAX_CONNECTIONS=100

# HTTP 最大保持连接数
HTTP_MAX_KEEPALIVE=20

# 模型列表缓存时间（秒）
MODEL_CACHE_TTL=3600
